<div class="bg-white p-6 rounded-2xl shadow w-full">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Daftar Mahasiswa</h2>
    <a href="/mahasiswa/create" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
      + Tambah Mahasiswa
    </a>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= success %>
    </div>
  <% } %>

  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-50 border-b">
          <th class="p-3 font-semibold text-gray-700">ID</th>
          <th class="p-3 font-semibold text-gray-700">Nama</th>
          <th class="p-3 font-semibold text-gray-700">NIM</th>
          <th class="p-3 font-semibold text-gray-700 text-center">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (mahasiswa.length > 0) { %>
          <% mahasiswa.forEach(m => { %>
            <tr class="border-b hover:bg-gray-50 transition">
              <td class="p-3 text-gray-600"><%= m.id %></td>
              <td class="p-3 text-gray-800 font-medium"><%= m.nama %></td>
              <td class="p-3 text-gray-600"><%= m.nim %></td>
              <td class="p-3 text-center flex justify-center gap-2">
                <a href="/mahasiswa/edit/<%= m.id %>" class="bg-yellow-500 text-white px-3 py-1 rounded hover:bg-yellow-600 text-sm">
                  Edit
                </a>
                <a href="/mahasiswa/delete/<%= m.id %>" 
                   onclick="return confirm('Yakin ingin menghapus?')"
                   class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                  Hapus
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" class="p-10 text-center text-gray-400">Belum ada data mahasiswa.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>