<!-- STATS CARDS -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-white p-6 rounded-xl shadow">
    <p class="text-sm text-gray-500">Total Mahasiswa</p>
    <p class="text-3xl font-bold text-blue-600"><%= totalMahasiswa %></p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow">
    <p class="text-sm text-gray-500">Total Dosen</p>
    <p class="text-3xl font-bold text-green-600">35</p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow">
    <p class="text-sm text-gray-500">Total Matkul</p>
    <p class="text-3xl font-bold text-purple-600">50</p>
  </div>
</div>

<!-- TABLE PREVIEW -->
<div class="bg-white p-6 rounded-xl shadow">
  <h2 class="text-lg font-bold mb-4">Data Mahasiswa</h2>
  <table class="w-full text-sm text-left">
    <thead class="bg-gray-100">
      <tr>
        <th class="p-3">No</th>
        <th class="p-3">Nama</th>
        <th class="p-3">NIM</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, i) => { %>
      <tr class="border-t">
        <td class="p-3"><%= i + 1 %></td>
        <td class="p-3"><%= m.nama %></td>
        <td class="p-3"><%= m.nim %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>