<div class="text-center py-10">
    <h2 class="text-3xl font-bold text-gray-800 mb-4"><%= title %></h2>
    <p class="text-lg text-gray-600 mb-8"><%= message %></p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <a href="/mahasiswa" class="p-6 bg-blue-50 border border-blue-200 rounded-xl hover:bg-blue-100 transition">
            <h3 class="text-xl font-semibold text-blue-700">Lihat Data</h3>
            <p class="text-sm text-gray-500">Manajemen data mahasiswa (CRUD)</p>
        </a>
        <a href="/mahasiswa/create" class="p-6 bg-green-50 border border-green-200 rounded-xl hover:bg-green-100 transition">
            <h3 class="text-xl font-semibold text-green-700">Tambah Baru</h3>
            <p class="text-sm text-gray-500">Input mahasiswa ke database SQLite</p>
        </a>
    </div>
</div>